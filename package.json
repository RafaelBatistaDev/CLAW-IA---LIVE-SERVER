{
  "name": "claw-ia-live-server",
  "displayName": "CLAW IA - Live Server",
  "description": "Servidor local para Visual Studio Code com live reload, HTTPS automático, multi-root e abertura na URL ativa do servidor.",
  "version": "1.1.3",
  "publisher": "RafaelBatista",
  "author": {
    "name": "Rafael Batista",
    "email": "rafael@clawia.dev",
    "url": "https://github.com/RafaelBatistaDev"
  },
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RafaelBatistaDev/CLAW-IA---LIVE-SERVER.git"
  },
  "homepage": "https://github.com/RafaelBatistaDev/CLAW-IA---LIVE-SERVER#readme",
  "bugs": {
    "url": "https://github.com/RafaelBatistaDev/CLAW-IA---LIVE-SERVER/issues",
    "email": "rafael@clawia.dev"
  },
  "preview": false,
  "galleryBanner": {
    "color": "#00263a",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.51.0"
  },
  "categories": ["Other"],
  "keywords": [
    "live-server", "live-reload", "local-server", "development-server",
    "vscode", "html", "css", "javascript", "typescript",
    "spa", "https", "web-preview", "open-in-browser",
    "hot-reload", "workspace", "multi-root", "static-server"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:claw.toggleServer",
    "onCommand:claw.startServer",
    "onCommand:claw.stopServer",
    "onCommand:claw.openExternal",
    "onCommand:claw.changeWorkspace",
    "onCommand:claw.showSettings"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claw.toggleServer",
        "title": "Toggle Live Server",
        "category": "CLAW"
      },
      {
        "command": "claw.startServer",
        "title": "Start Live Server",
        "category": "CLAW"
      },
      {
        "command": "claw.stopServer",
        "title": "Stop Live Server",
        "category": "CLAW"
      },
      {
        "command": "claw.openExternal",
        "title": "Open in External Browser",
        "category": "CLAW"
      },
      {
        "command": "claw.changeWorkspace",
        "title": "Change Live Server Workspace",
        "category": "CLAW"
      },
      {
        "command": "claw.showSettings",
        "title": "Open Live Server Settings",
        "category": "CLAW"
      }
    ],
    "keybindings": [
      {
        "command": "claw.startServer",
        "key": "alt+L alt+O",
        "when": "editorTextFocus",
        "mac": "cmd+L cmd+O"
      },
      {
        "command": "claw.stopServer",
        "key": "alt+L alt+C",
        "when": "editorTextFocus",
        "mac": "cmd+L cmd+C"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "claw.startServer",
          "group": "claw@liveServer",
          "when": "resourceLangId == html"
        },
        {
          "command": "claw.stopServer",
          "group": "claw@liveServer",
          "when": "resourceLangId == html"
        },
        {
          "command": "claw.startServer",
          "group": "claw@liveServer",
          "when": "resourceLangId == xml"
        }
      ],
      "explorer/context": [
        {
          "command": "claw.startServer",
          "group": "navigation@-claw",
          "when": "resourceLangId == html"
        },
        {
          "command": "claw.startServer",
          "group": "navigation@-claw",
          "when": "resourceLangId == xml"
        }
      ]
    },
    "configuration": {
      "title": "CLAW IA - Live Server Config",
      "properties": {
        "liveServer.settings.port": {
          "type": "number",
          "default": 5500,
          "minimum": 0,
          "maximum": 65535,
          "description": "Porta do servidor. Use 0 para porta aleatória."
        },
        "liveServer.settings.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host do servidor. Ex: 127.0.0.1 ou localhost."
        },
        "liveServer.settings.root": {
          "type": "string",
          "default": "/",
          "pattern": "/|/[^\\/]",
          "description": "Pasta raiz do servidor relativa ao workspace."
        },
        "liveServer.settings.noBrowser": {
          "type": "boolean",
          "default": false,
          "description": "Se true, inicia o servidor sem abrir o painel de preview."
        },
        "liveServer.settings.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Exibe o botão CLAW na barra de status."
        },
        "liveServer.settings.statusBarAlignment": {
          "type": "string",
          "default": "right",
          "enum": ["left", "right"],
          "description": "Alinhamento do botão na barra de status."
        },
        "liveServer.settings.statusBarPriority": {
          "type": "number",
          "default": 100,
          "description": "Prioridade do botão na barra de status. Maior = mais à direita/esquerda."
        },
        "liveServer.settings.CustomBrowser": {
          "type": ["string", "null"],
          "default": null,
          "enum": ["chrome", "chrome:PrivateMode", "firefox", "firefox:PrivateMode", "microsoft-edge", "blisk", null],
          "description": "Navegador externo para abrir ao usar 'Open in External Browser'."
        },
        "liveServer.settings.fullReload": {
          "type": "boolean",
          "default": false,
          "description": "Se true, faz reload completo ao salvar. Se false, injeta CSS sem reload."
        },
        "liveServer.settings.wait": {
          "type": "number",
          "default": 100,
          "description": "Delay em ms antes de recarregar após salvar."
        },
        "liveServer.settings.donotShowInfoMsg": {
          "type": "boolean",
          "default": false,
          "description": "Desativa mensagens informativas pop-up."
        },
        "liveServer.settings.donotVerifyTags": {
          "type": "boolean",
          "default": false,
          "description": "Desativa aviso de tags HTML faltando (body, head, etc)."
        },
        "liveServer.settings.cors": {
          "type": "boolean",
          "default": false,
          "description": "Habilita CORS adicionando 'Access-Control-Allow-Origin: *' nas respostas."
        },
        "liveServer.settings.useLocalIp": {
          "type": "boolean",
          "default": false,
          "description": "Usa o IP local da máquina como host."
        },
        "liveServer.settings.useWebExt": {
          "type": "boolean",
          "default": false,
          "description": "Habilita integração com extensão do navegador (útil para páginas dinâmicas como PHP)."
        },
        "liveServer.settings.https": {
          "type": "object",
          "default": { "enable": false, "cert": "", "key": "", "passphrase": "" },
          "properties": {
            "enable": { "type": "boolean", "default": false },
            "cert":   { "type": "string",  "default": "" },
            "key":    { "type": "string",  "default": "" },
            "passphrase": { "type": "string", "default": "" }
          },
          "required": ["enable", "cert", "key", "passphrase"],
          "additionalProperties": false,
          "description": "Configuração HTTPS com certificado próprio."
        },
        "liveServer.settings.proxy": {
          "type": "object",
          "default": { "enable": false, "baseUri": "/", "proxyUri": "http://127.0.0.1:80" },
          "properties": {
            "enable":   { "type": "boolean", "default": false },
            "baseUri":  { "type": "string",  "default": "/" },
            "proxyUri": { "type": "string",  "default": "http://127.0.0.1:80" }
          },
          "required": ["enable", "baseUri", "proxyUri"],
          "additionalProperties": false,
          "description": "Configuração de proxy reverso."
        },
        "liveServer.settings.headers": {
          "type": "object",
          "default": {},
          "description": "Headers HTTP adicionais nas respostas."
        },
        "liveServer.settings.mount": {
          "type": "array",
          "default": [],
          "description": "Monta pastas em rotas. Ex: [['/components', './node_modules']]"
        },
        "liveServer.settings.file": {
          "type": "string",
          "default": "",
          "description": "Arquivo a servir para todo 404 (útil para SPAs)."
        },
        "liveServer.settings.ignoreFiles": {
          "type": "array",
          "default": [
            ".vscode/**", "**/*.scss", "**/*.sass",
            "**/*.ts", "node_modules/**", "venv/**", ".venv/**"
          ],
          "description": "Arquivos cujas mudanças não disparam o reload."
        },
        "liveServer.settings.multiRootWorkspaceName": {
          "type": "string",
          "default": null,
          "description": "Workspace de entrada em projetos multi-root."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "package": "vsce package --out claw-ia-live-server-1.1.3.vsix",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/express": "^4.17.14",
    "@types/glob": "^7.1.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.51.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-electron": "^2.0.1",
    "typescript": "^4.7.0",
    "@vscode/vsce": "^3.0.0",
    "ws": "^8.20.0"
    },
  "dependencies": {
    "chokidar": "^3.5.3",
    "express": "^4.18.2",
    "express-http-proxy": "^2.1.0",
    "express-rate-limit": "^6.7.0",
    "open": "^9.0.0",
    "selfsigned": "^1.10.14"
  }
}
