{
  "name": "claw-ia-live-server",
  "displayName": "CLAW IA - LIVE SERVER",
  "description": "VS Code extension for live reload server with HTML, CSS and multiple programming languages support.",
  "version": "1.0.6",
  "publisher": "RafaelBatista",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RafaelBatistaDev/CLAW-IA---LIVE-SERVER.git"
  },
  "homepage": "https://github.com/RafaelBatistaDev/CLAW-IA---LIVE-SERVER#readme",
  "bugs": {
    "url": "https://github.com/RafaelBatistaDev/CLAW-IA---LIVE-SERVER/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "live",
    "reload",
    "server",
    "http",
    "development",
    "html",
    "css",
    "javascript",
    "react",
    "vite"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:claw.startServer",
    "onCommand:claw.stopServer",
    "onCommand:claw.openExternal"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claw.startServer",
        "title": "CLAW: Iniciar Servidor",
        "icon": "$(play)"
      },
      {
        "command": "claw.stopServer",
        "title": "CLAW: Parar Servidor",
        "icon": "$(debug-stop)"
      },
      {
        "command": "claw.openExternal",
        "title": "CLAW: Abrir no Navegador Externo",
        "icon": "$(browser)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "claw.openExternal",
          "group": "navigation",
          "when": "editorLangId == html || editorLangId == css || editorLangId == javascript || editorLangId == typescript || editorLangId == javascriptreact || editorLangId == typescriptreact"
        },
        {
          "command": "claw.startServer",
          "group": "navigation",
          "when": "editorLangId == html || editorLangId == css || editorLangId == javascript || editorLangId == typescript || editorLangId == javascriptreact || editorLangId == typescriptreact"
        }
      ],
      "editor/context": [
        {
          "command": "claw.openExternal",
          "group": "navigation",
          "when": "editorLangId == html || editorLangId == css || editorLangId == javascript || editorLangId == typescript || editorLangId == javascriptreact || editorLangId == typescriptreact"
        },
        {
          "command": "claw.startServer",
          "group": "navigation",
          "when": "editorLangId == html || editorLangId == css || editorLangId == javascript || editorLangId == typescript || editorLangId == javascriptreact || editorLangId == typescriptreact"
        }
      ],
      "commandPalette": [
        {
          "command": "claw.startServer"
        },
        {
          "command": "claw.stopServer"
        },
        {
          "command": "claw.openExternal"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/express": "^4.17.14",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.70.0",
    "@types/ws": "^8.18.1",
    "eslint": "^8.0.0",
    "typescript": "^4.7.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "open": "^9.0.0",
    "selfsigned": "^1.10.14",
    "ws": "^8.13.0"
  }
}
