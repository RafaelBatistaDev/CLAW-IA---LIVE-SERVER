{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "skipLibCheck": true,
    "outDir": "out",
    "lib": [
      "es6",
      "DOM"
    ],
    "sourceMap": true,
    "esModuleInterop": true,
    "rootDir": "src",
    "types": [
      "node",
      "mocha"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "_site"
  ]
}
