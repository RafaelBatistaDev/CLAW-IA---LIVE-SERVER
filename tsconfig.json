{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "skipLibCheck": true,
    "outDir": "out",
    "lib": [
      "es6",
      "DOM"
    ],
    "sourceMap": true,
    "esModuleInterop": true,
    "rootDir": "src",
    "types": [
      "node",
      "mocha"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "_site",
    "out",
    "**/*.html",
    "**/*.css",
    "**/*.scss",
    "**/*.sass",
    "**/*.md"
  ]
}
